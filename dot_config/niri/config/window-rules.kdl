/-window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

/-window-rule {
    match app-id="^mpv$"
    match app-id="^hl_linux$"
    match app-id="^steam_app_524220$" // NieR:Automata
    variable-refresh-rate true
    default-column-width {}
}

