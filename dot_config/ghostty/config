# Cursor
cursor-style = block
cursor-style-blink = false


# fonts
font-size = 10
# font-family = JetBrainsMono Nerd Font
# font-family = "MonaspiceNe Nerd Font"
# font-family = "Iosevka Nerd Font Mono"
font-family = CaskaydiaCove Nerd Font
font-feature = -liga

# Background
background-opacity = 0.98

adjust-cell-width = 0
adjust-cell-height = -10%

# Window
# gtk-single-instance = true
# gtk-wide-tabs = false
window-padding-x = 3,3
window-padding-y = 3,0
window-padding-balance = true
window-decoration = auto
window-show-tab-bar = auto
window-theme = ghostty
confirm-close-surface = false
resize-overlay = never
# gtk-adwaita = false
title = "Ghostty"

#Shell
shell-integration = bash

# URL Detection and Clicking
# Enable automatic URL detection
link-url = true
# Open URLs with Cmd+Click (bypasses Zellij mouse mode)
# Ghostty will detect URLs and make them clickable
# theming


theme = noctalia
# theme = catppuccin-mocha
# theme = vesper
# theme = Gitlab-Dark-Grey
# theme = dark:Japanesque,light:Monokai Pro Light Sun
# theme = AdwaitaDark
# theme = light:Monokai Pro Light Sun
# theme = Novel
# theme = NvimDark

# general
shell-integration-features = no-cursor,sudo,no-title,ssh-terminfo,ssh-env

# keybinds
# keybind = ctrl+shift+x=close_surface
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+v=paste_from_clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+a=select_all
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
# keybinds split create
keybind = alt+ctrl+right=new_split:right
keybind = alt+ctrl+left=new_split:left
keybind = alt+ctrl+up=new_split:up
keybind = alt+ctrl+down=new_split:down
keybind = alt+q=close_surface
# keybinds split goto
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+k=goto_split:top
keybind = alt+j=goto_split:bottom
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom
# keybinds to resize split
keybind = alt+shift+left=resize_split:left,10
keybind = alt+shift+right=resize_split:right,10
keybind = alt+shift+up=resize_split:up,10
keybind = alt+shift+down=resize_split:down,10
# keybinds tabs
keybind = ctrl+t=new_tab
keybind = ctrl+right=next_tab
keybind = ctrl+left=previous_tab
# other
copy-on-select = clipboard

